{
  "name": "content-engine-lite",
  "version": "1.0.0",
  "description": "Free content repurposing starter. Takes raw content and outputs 5 clips for Instagram Reels + LinkedIn with 10 hook formulas and a 3-post/week calendar. Upgrade to full version at koino.capital/kits.",
  "author": "KOINO Capital",
  "license": "free",
  "category": "content",
  "tags": ["content", "repurposing", "social-media", "short-form", "hooks", "free", "lite"],
  "upstream": {
    "full_version": "content-engine",
    "upgrade_url": "https://koino.capital/kits"
  },
  "requires": {
    "tools": ["ollama", "jq"],
    "models": ["qwen2.5:3b"],
    "env_vars": []
  },
  "inputs": {
    "source": {
      "type": "string",
      "required": true,
      "description": "Path to raw content file (transcript, blog post, video notes)"
    },
    "brand_name": {
      "type": "string",
      "required": false,
      "description": "Brand or creator name"
    },
    "tone": {
      "type": "string",
      "required": false,
      "default": "conversational, direct",
      "description": "Desired tone (e.g. 'edgy, no-BS' or 'warm, professional')"
    },
    "topics": {
      "type": "string",
      "required": false,
      "description": "Core content topics (comma-separated)"
    },
    "clips": {
      "type": "integer",
      "required": false,
      "default": 5,
      "max": 5,
      "description": "Number of clips to generate (max 5 in lite)"
    }
  },
  "outputs": {
    "clips/": "5 clip files with hook, body, CTA — Instagram Reels + LinkedIn versions",
    "calendar.md": "3-post/week schedule"
  },
  "limits": {
    "max_clips": 5,
    "platforms": ["instagram", "linkedin"],
    "hook_formulas": 10
  },
  "estimated_tokens": {
    "per_run": "~8,000 tokens input + ~12,000 tokens output",
    "cost_local_ollama": "$0.00"
  }
}
